		{"id":"06aab73da775eb39","type":"text","text":"","x":4940,"y":500,"width":380,"height":60,"color":"2"},
		{"id":"42c511fcf3986fa2","type":"text","text":"","x":1740,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"08da54da7b66389f","type":"text","text":"","x":1740,"y":820,"width":380,"height":70,"color":"4"},
