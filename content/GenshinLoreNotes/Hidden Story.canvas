		{"id":"ede9b1b12a289719","type":"text","text":"MC - Life of bloodshed","x":6620,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"48efb08ad15b073e","type":"text","text":"Guardian: King, large, mountain","x":6620,"y":820,"width":380,"height":60,"color":"4"},
		{"id":"cc82622a7f809971","type":"text","text":"Sitting atop Irminsul","x":6620,"y":980,"width":380,"height":60,"color":"5"},
