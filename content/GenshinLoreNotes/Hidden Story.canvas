		{"id":"e636fbf210271c04","type":"text","text":"","x":1740,"y":1220,"width":380,"height":60,"color":"6"},
		{"id":"36d2974f1c5d2d4d","type":"text","text":"","x":1740,"y":1480,"width":380,"height":60,"color":"1"},
		{"id":"7282b30605a21e32","type":"text","text":"","x":2140,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"218a72c2839f0050","type":"text","text":"","x":2140,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"0308c2f81c7d2d6d","type":"text","text":"","x":2540,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"d18b7a07b97fc68e","type":"text","text":"","x":2140,"y":820,"width":380,"height":70,"color":"4"},
		{"id":"766b11bc632b769d","type":"text","text":"","x":2540,"y":820,"width":380,"height":70,"color":"4"},
		{"id":"8cdf6fb4de8bae79","type":"text","text":"","x":2140,"y":980,"width":380,"height":60,"color":"5"},
		{"id":"a17c350712e2f691","type":"text","text":"==Upon the tree=='s tower-like branches ==perched a raven==.","x":2540,"y":980,"width":380,"height":60,"color":"5"},
		{"id":"c8366b559f61751e","type":"text","text":"The sword had extinguished after the world was burned, but having assimilated the rune of the fire realm, it burned bright once more.","x":2140,"y":1220,"width":380,"height":120,"color":"6"},
		{"id":"c91eaf9e4289940a","type":"text","text":"","x":2540,"y":1220,"width":380,"height":60,"color":"6"},
		{"id":"3c7d0fb2bac2c709","type":"text","text":"","x":2540,"y":1480,"width":380,"height":60,"color":"1"},
		{"id":"dbd171a1752cf465","type":"text","text":"","x":2140,"y":1480,"width":380,"height":60,"color":"1"},
		{"id":"77bc627157bb6cba","type":"text","text":"","x":2140,"y":500,"width":380,"height":60,"color":"2"},
		{"id":"82753e3f17ae1b48","type":"text","text":"","x":2140,"y":500,"width":380,"height":60,"color":"2"},
		{"id":"37a7acea06bb9470","type":"text","text":"","x":2540,"y":500,"width":380,"height":60,"color":"2"},
		{"id":"904092fe5cdb6a48","type":"text","text":"","x":1740,"y":500,"width":380,"height":60,"color":"2"},
		{"id":"a92c24bcd7dcbd80","type":"text","text":"","x":940,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"2acb3506b14e54a6","type":"text","text":"","x":1340,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"0d5f9c1625c86c9a","type":"text","text":"The solemn and silent ==king== yet sat upon his ==massive== chiseled white throne, the scepter in his hands not yet eaten away by insects...","x":940,"y":820,"width":380,"height":140,"color":"4"},
		{"id":"155325cfde85fd66","type":"text","text":"","x":1340,"y":820,"width":380,"height":70,"color":"4"},
		{"id":"ab90d204197bebbe","type":"text","text":"The solemn and silent king yet ==sat upon his massive chiseled white throne==","x":940,"y":980,"width":380,"height":100,"color":"5"},
		{"id":"36fe5e9f29cd8086","type":"text","text":"","x":1340,"y":980,"width":380,"height":60,"color":"5"},
		{"id":"042f538f2ece91d9","type":"text","text":"","x":940,"y":1220,"width":380,"height":60,"color":"6"},
		{"id":"7075a6b40e44f1cc","type":"text","text":"","x":1340,"y":1220,"width":380,"height":60,"color":"6"},
		{"id":"67d5cfcdc1afc08f","type":"text","text":"","x":1340,"y":1480,"width":380,"height":60,"color":"1"},
		{"id":"6caec67b079204da","type":"text","text":"","x":940,"y":1480,"width":380,"height":60,"color":"1"},
		{"id":"1668949e94b44176","type":"text","text":"","x":1340,"y":500,"width":380,"height":60,"color":"2"},
		{"id":"ff60644f8ff47f49","type":"text","text":"\"Beautiful yet treacherous life, twisted and violent monsters, one by one awakened from their thousand-year slumber...\"","x":940,"y":500,"width":380,"height":120,"color":"2"},
		{"id":"47b17c65650242b5","type":"text","text":"","x":540,"y":500,"width":380,"height":60,"color":"2"},
		{"id":"7793521219ae6203","type":"text","text":"In the heart of Huitztlan lies the \"Mountain ==King==\" Kongamato, a ==gargantuan== creature like the ==mountains== among which it sleeps.","x":540,"y":820,"width":380,"height":120,"color":"4"},
		{"id":"32a0a15b18dc14c5","type":"text","text":"","x":540,"y":980,"width":380,"height":60,"color":"5"},
		{"id":"a3000b95b7df9fba","type":"text","text":"","x":540,"y":1220,"width":380,"height":60,"color":"6"},
		{"id":"a899e006b5a207d5","type":"text","text":"","x":540,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"9efe5def0497fdcf","type":"text","text":"","x":540,"y":1480,"width":380,"height":60,"color":"1"},
		{"id":"8319d5d1aa228ffb","type":"text","text":"Yet the fae ==king==, ==towering== as a ==mountain==...","x":-660,"y":820,"width":380,"height":80,"color":"4"},
		{"id":"0164cb10d32535bf","type":"text","text":"No priests, however, remained to tend the ==white tree==. In their place, something else had taken root — something that named itself king, and ==watched from the high boughs== left behind by a vanished envoy.","x":-660,"y":980,"width":380,"height":220,"color":"5"},
		{"id":"fe48136d09c750f8","type":"text","text":"\"his life steeped in war and chaos\"","x":-260,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"21318b73bf63e109","type":"text","text":"","x":-260,"y":820,"width":380,"height":60,"color":"4"},
		{"id":"4abfdb555d7fe1c3","type":"text","text":"","x":-260,"y":980,"width":380,"height":60,"color":"5"},
		{"id":"f1b9134cadd7ced3","type":"text","text":"","x":-260,"y":1220,"width":380,"height":60,"color":"6"},
		{"id":"1be32b104369da6f","type":"text","text":"","x":-660,"y":1220,"width":380,"height":60,"color":"6"},
		{"id":"3f284a64b204dac0","type":"text","text":"","x":-660,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"633b6f062ef15e5e","type":"text","text":"\"Long years of bloodshed\"","x":140,"y":640,"width":380,"height":60,"color":"3"},
		{"id":"55ad02fd53779bac","type":"text","text":"","x":140,"y":820,"width":380,"height":60,"color":"4"},
		{"id":"448ca97daebde8b9","type":"text","text":"","x":140,"y":980,"width":380,"height":60,"color":"5"},
