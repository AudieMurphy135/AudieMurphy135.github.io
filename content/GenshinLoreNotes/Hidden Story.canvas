		{"id":"3bbcfc0d8fe7a792","type":"text","text":"Only when the gentle starlight brushed against mine eyes, unveiling itself to me ==atop the white stone mountain of song==...","x":2940,"y":980,"width":380,"height":120,"color":"5"},
